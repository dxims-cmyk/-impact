# ===========================================
# : IMPACT ENGINE - Environment Variables
# ===========================================
# Copy to .env.local and fill in values

# -------------------------------------------
# Core (REQUIRED)
# -------------------------------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Trigger.dev (Background Jobs)
TRIGGER_API_KEY=tr_dev_...
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_API_URL=https://api.trigger.dev

# Encryption (for storing OAuth tokens — 32-byte hex string)
ENCRYPTION_KEY=

# Admin emails (comma-separated, used for auto-assigning agency role)
ADMIN_EMAILS=admin@example.com

# -------------------------------------------
# Notifications (REQUIRED)
# -------------------------------------------

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Your App <noreply@yourdomain.com>

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token

# -------------------------------------------
# Meta / Facebook / Instagram
# -------------------------------------------

META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=your-verify-token
META_PAGE_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=

# -------------------------------------------
# Payments & Billing
# -------------------------------------------

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_PRICE_CORE=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# Stripe Add-on Prices
ADDON_PRICE_AI_RECEPTIONIST=price_...
ADDON_PRICE_OUTBOUND=price_...

# Xero (invoicing — optional)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_WEBHOOK_KEY=

# -------------------------------------------
# AI Features (optional)
# -------------------------------------------

# Vapi (AI Receptionist)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# -------------------------------------------
# Scheduling (optional)
# -------------------------------------------

# Cal.com
CAL_API_KEY=cal_live_...

# Google Calendar (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Calendly (OAuth)
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=

# -------------------------------------------
# Advertising (optional)
# -------------------------------------------

# Google Ads (OAuth)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# TikTok Ads (OAuth)
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# -------------------------------------------
# Messaging (optional / legacy)
# -------------------------------------------

# Slack (OAuth)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Twilio (SMS — legacy, WhatsApp now uses Meta Cloud API)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+44...

# -------------------------------------------
# Outbound Leads (Google Places via Apify)
# -------------------------------------------
APIFY_TOKEN=

# -------------------------------------------
# Monitoring (optional)
# -------------------------------------------

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
