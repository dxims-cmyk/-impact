# ===========================================
# : IMPACT ENGINE - Environment Variables
# ===========================================

# -------------------------------------------
# Core
# -------------------------------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Trigger.dev (Background Jobs)
TRIGGER_API_KEY=tr_dev_...
TRIGGER_API_URL=https://api.trigger.dev

# Encryption (for storing OAuth tokens)
ENCRYPTION_KEY=32-byte-hex-string

# -------------------------------------------
# AI Features
# -------------------------------------------

# Vapi (AI Receptionist)
VAPI_API_KEY=...
VAPI_WEBHOOK_SECRET=...

# -------------------------------------------
# Notifications
# -------------------------------------------

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
META_WEBHOOK_VERIFY_TOKEN=your-verify-token

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=AM:PM Media <noreply@yourdomain.com>

# Twilio (SMS — legacy, WhatsApp now uses Meta Cloud API)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+44...

# Slack (OAuth)
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...

# -------------------------------------------
# Scheduling
# -------------------------------------------

# Cal.com
CAL_API_KEY=cal_live_...

# Google Calendar (OAuth)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Calendly (OAuth)
CALENDLY_CLIENT_ID=...
CALENDLY_CLIENT_SECRET=...

# -------------------------------------------
# Advertising
# -------------------------------------------

# Meta Ads (OAuth)
META_APP_ID=...
META_APP_SECRET=...

# Google Ads (OAuth)
GOOGLE_ADS_CLIENT_ID=...
GOOGLE_ADS_CLIENT_SECRET=...
GOOGLE_ADS_DEVELOPER_TOKEN=...

# TikTok Ads (OAuth — optional)
TIKTOK_APP_ID=...
TIKTOK_APP_SECRET=...

# -------------------------------------------
# Payments & Invoicing
# -------------------------------------------

# Stripe Connect (client payment collection)
STRIPE_CLIENT_ID=ca_...
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# Xero (invoicing)
XERO_CLIENT_ID=...
XERO_CLIENT_SECRET=...
XERO_WEBHOOK_KEY=...

# -------------------------------------------
# Monitoring (optional)
# -------------------------------------------

# Sentry
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
